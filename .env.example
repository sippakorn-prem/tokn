# Signing + notarization secrets for `make release`.
# Copy to `.env` (gitignored) and fill in. All four are required.

# 1. Your "Developer ID Application" certificate's full name.
#    Find it after installing the cert:  security find-identity -v -p codesigning
#    Looks like:  Developer ID Application: Your Name (TEAMID1234)
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID1234)"

# 2. The Apple ID email of your developer account.
APPLE_ID="you@example.com"

# 3. An app-specific password (NOT your normal Apple ID password).
#    Create at: https://account.apple.com  ->  Sign-In & Security  ->  App-Specific Passwords
APPLE_PASSWORD="abcd-efgh-ijkl-mnop"

# 4. Your 10-character Team ID.
#    Find at: https://developer.apple.com/account  (Membership details), or in the cert name above.
APPLE_TEAM_ID="TEAMID1234"
